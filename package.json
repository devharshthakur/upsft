{
  "name": "upsft",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "dev": "cargo run",
    "start": "cargo run --release",
    "build": "cargo build",
    "build:release": "cargo build --release",
    "lint": "cargo clippy --fix --allow-dirty --all-features",
    "format": "prettier --write . && cargo fmt",
    "test": "cargo test",
    "test:cli": "cargo run --release -- --config test/test.config.toml",
    "prepare": "husky",
    "changelog": "tsx scripts/changelog.ts",
    "changelog:unreleased": "git cliff --unreleased --prepend CHANGELOG.md",
    "release": "tsx scripts/release.ts",
    "tag": "tsx scripts/tag.ts"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0"
  }
}
