{
  "name": "upsft",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "dev": "cargo run",
    "start": "cargo run --release",
    "build": "cargo build",
    "build:release": "cargo build --release",
    "lint": "cargo clippy --fix --allow-dirty --all-features",
    "format": "prettier --write . && cargo fmt",
    "test": "cargo test",
    "test:cli": "cargo run --release -- --config test/test.config.toml",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4"
  }
}
