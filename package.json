{
  "name": "upsft",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "cargo run",
    "start": "cargo run --release",
    "build": "cargo build",
    "build:release": "cargo build --release",
    "lint": "cargo clippy --fix --allow-dirty --all-features",
    "format": "prettier --write . && cargo fmt",
    "test": "cargo test",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  }
}
