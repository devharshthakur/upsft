{
  "name": "upsft",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "dev": "cargo run",
    "start": "cargo run --release",
    "build": "cargo build",
    "build:release": "cargo build --release",
    "lint": "cargo clippy --all-features -- -D warnings",
    "lint:fix": "cargo clippy --fix --allow-dirty --all-features",
    "format": "prettier --write --experimental-cli . && cargo fmt",
    "check": "prettier --check . && cargo fmt --check && cargo clippy --all-features -- -D warnings && cargo build --release",
    "prepare": "husky",
    "changelog:unreleased": "git-cliff --unreleased --prepend CHANGELOG.md",
    "changelog:release": "git-cliff --latest --prepend CHANGELOG.md"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.5"
  }
}
